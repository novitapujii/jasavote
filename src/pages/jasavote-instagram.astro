---
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout>

<section class="vote-hero">

  <div class="container vote-hero-grid">

    <div class="vote-hero-content">

      <span class="badge">Jasa Vote Instagram</span>

      <h1>
        Jasa Vote Instagram
        Aman & Cepat
      </h1>

      <p>
        Tingkatkan peluang kemenangan kontes Instagram dengan layanan vote terpercaya,
        cepat masuk, aman, dan anti drop.
      </p>

      <div class="vote-buttons">

        <a
          href="https://wa.me/6281234567890"
          class="btn-primary"
          target="_blank"
        >
          Pesan Sekarang
        </a>

        <a
          href="#faq"
          class="btn-secondary"
        >
          Pelajari Dulu
        </a>

      </div>

    </div>

    <div class="vote-hero-image">

      <img
        src="/hero-jasavote.png"
        alt="Jasa Vote Instagram"
        loading="eager"
      />

    </div>

  </div>

</section>


<section class="vote-features">

  <div class="container">

    <div class="section-title">
      <h2>Kenapa Memilih Kami?</h2>
      <p>Layanan profesional untuk membantu kemenangan vote Instagram Anda.</p>
    </div>

    <div class="feature-grid">

      <div class="feature-card">
</DefaultLayout>
