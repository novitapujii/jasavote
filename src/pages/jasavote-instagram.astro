  display: flex;
  gap: 16px;
}

.btn-primary,
.btn-secondary,
.cta-button {
  padding: 14px 28px;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 700;
}

.btn-primary,
.cta-button {
  background: #22c55e;
  color: white;
}

.btn-secondary {
  border: 2px solid #2563eb;
  color: #2563eb;
}

.vote-hero-image img {
  width: 100%;
}

