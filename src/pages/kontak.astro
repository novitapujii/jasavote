---
import DefaultLayout from "../layouts/DefaultLayout.astro";
---

<DefaultLayout>

  <section class="contact-page">

    <h1>
      Hubungi Jasa Vote Aman, Cepat, dan Terpercaya
    </h1>

    <p class="contact-intro">
      Konsultasikan kebutuhan campaign, kontes, polling,
      dan jasa vote Anda bersama tim kami.
    </p>


    <div class="contact-grid">

      <!-- whatsapp -->

      <div class="contact-card">

        <h3>WhatsApp</h3>

        <p>
          Fast response 24 jam.
        </p>

        <a
          href="https://wa.me/628xxxxxxxxxx"
          target="_blank"
        >
          Chat Sekarang
        </a>

      </div>



      <!-- telegram -->

      <div class="contact-card">

        <h3>Telegram</h3>

        <p>
          Konsultasi cepat dan fleksibel.
        </p>

        <a href="#">
          Buka Telegram
        </a>

      </div>



      <!-- email -->

      <div class="contact-card">

        <h3>Email</h3>

        <p>
          Untuk kebutuhan bisnis dan partnership.
        </p>

        <a href="mailto:admin@email.com">
          Kirim Email
        </a>

      </div>

    </div>



    <!-- jam operasional -->

    <div class="business-hours">

      <h2>Jam Operasional</h2>

      <p>
        Senin - Minggu • 24 Jam
      </p>

    </div>



    <!-- CTA -->

    <section class="contact-cta">

      <h2>
        Butuh Respon Cepat?
      </h2>

      <a
        href="https://wa.me/6289634740308"
        target="_blank"
      >
        Hubungi Admin Sekarang
      </a>

    </section>

  </section>

</DefaultLayout>