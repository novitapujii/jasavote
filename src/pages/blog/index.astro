---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---

<DefaultLayout>

<section class="blog-page">

  <div class="blog-container">

    <div class="blog-header">
      <h1>Blog Jasa Vote</h1>

      <p class="blog-intro">
        Tips dan strategi vote online aman.
      </p>
    </div>

    <div class="blog-layout">

      <!-- LEFT -->
      <div class="blog-list">

        {posts.map((post: any) => (

          <article class="blog-card">

            <div class="blog-image">
              <img
                src={post.data.image}
                alt={post.data.title}
              />
            </div>

            <div class="blog-content">

              <span class="blog-category">
                {post.data.category}
              </span>

              <a href={`/blog/${post.id}`}>
                <h2>{post.data.title}</h2>
              </a>

              <p>{post.data.description}</p>

              <div class="blog-meta">
                {post.data.date}
              </div>

            </div>

          </article>

        ))}

      </div>

      <!-- RIGHT -->
      <aside class="blog-sidebar">

        <div class="sidebar-widget">

          <h3>Recent Posts</h3>

          {posts.map((post: any) => (

            <div class="recent-post">

              <img
                src={post.data.image}
                alt={post.data.title}
              />

              <div>

                <a href={`/blog/${post.id}`}>
                  {post.data.title}
                </a>

                <span>
                  {post.data.date}
                </span>

              </div>

            </div>

          ))}

        </div>

      </aside>

    </div>

  </div>

</section>

</DefaultLayout>