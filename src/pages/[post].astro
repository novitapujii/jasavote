---
import DefaultLayout from "@layouts/DefaultLayout.astro";
import { getCollection } from "astro:content";

// Generate semua slug artikel
export async function getStaticPaths() {

  const posts = await getCollection<any>("blog");

  return posts.map((post: any) => ({
    params: {
      post: post.id,
    },

    props: {
      post,
    },
  }));
}

const { post }: any = Astro.props;

// Render markdown
const { Content } = await post.render();

// Author default Jasa Vote
const author = {
  name: "Tim Jasa Vote",
  image: "/logo-jasavote.png",
  bio: "Spesialis jasa vote, polling, dan optimasi sosial media.",
};

// URL artikel
const currentUrl = `https://jasavote.my.id/blog/${post.id}/`;
---

<DefaultLayout title={`${post.data.title} | Blog Jasa Vote`}>

  <!-- HERO -->
  <section class="article-hero">

    <div class="article-container">

      <span class="article-category">
        {post.data.category}
      </span>

      <h1>{post.data.title}</h1>

      <p class="article-description">
        {post.data.description}
      </p>

      <div class="article-meta">

        <div class="article-author">

          <img
            src={author.image}
            alt={author.name}
          />

          <div>

            <strong>{author.name}</strong>

            <span>
              {post.data.date}
            </span>

          </div>

        </div>

      </div>

      <img
        src={post.data.image}
        alt={post.data.title}
        class="article-image"
      />

    </div>

  </section>

  <!-- CONTENT -->
  <section class="article-content-section">

    <div class="article-container">

      <article class="article-content">
        <Content />
      </article>

    </div>

  </section>

  <!-- SHARE -->
  <section class="article-share">

    <div class="article-container">

      <h2>Bagikan Artikel Ini</h2>

      <p>
        Bermanfaat? Bagikan artikel ini ke teman Anda.
      </p>

      <div class="share-buttons">

        <a
          href={`https://wa.me/?text=${currentUrl}`}
          target="_blank"
        >
          WhatsApp
        </a>

        <a
          href={`https://t.me/share/url?url=${currentUrl}`}
          target="_blank"
        >
          Telegram
        </a>

        <a
          href={`https://www.facebook.com/sharer/sharer.php?u=${currentUrl}`}
          target="_blank"
        >
          Facebook
        </a>

      </div>

    </div>

  </section>

</DefaultLayout>